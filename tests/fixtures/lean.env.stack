# CI fixture: Traefik + Watchtower only (no HTTPS panels, no registry).
# shellcheck disable=SC1091
source "$(dirname "${BASH_SOURCE[0]}")/_common.env.stack"

ENABLE_TRAEFIK=1
ENABLE_PORTAINER=0
ENABLE_DOKU=0
ENABLE_WATCHTOWER=1
ENABLE_SEMAPHORE=0
ENABLE_DUPLICATI=0
ENABLE_UPTIME_KUMA=0
ENABLE_FILEBROWSER=0
ENABLE_REGISTRY=0
ENABLE_DOCKER_AUTH=0
COMPOSE_PROFILES=traefik,watchtower
