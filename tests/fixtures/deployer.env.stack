# CI fixture: default stack + Deployer profile (no image pull).
# shellcheck disable=SC1091
source "$(dirname "${BASH_SOURCE[0]}")/_common.env.stack"

ENABLE_TRAEFIK=1
ENABLE_PORTAINER=1
ENABLE_DOKU=1
ENABLE_WATCHTOWER=1
ENABLE_SEMAPHORE=1
ENABLE_DUPLICATI=1
ENABLE_UPTIME_KUMA=1
ENABLE_FILEBROWSER=1
ENABLE_REGISTRY=1
ENABLE_DOCKER_AUTH=1
DEPLOYER_IMAGE=docker.io/example/deployer:ci
DEPLOYER_IMAGE_EFFECTIVE=docker.io/example/deployer:ci
DEPLOYER_REGISTRY_HOST=registry.ci.stack.test
COMPOSE_PROFILES=traefik,portainer,doku,watchtower,semaphore,duplicati,kuma,filebrowser,registry,docker-auth,deployer
