# Shared CI fixture values (sourced by tests/fixtures/*.env.stack — not used directly).
STACK_ROOT=/tmp/setup-server-stack-ci
DOMAIN=ci.stack.test
ACME_EMAIL=ci@stack.test
STACK_ADMIN_USER=admin
STACK_ADMIN_EMAIL=admin@ci.stack.test
TZ=UTC
TRAEFIK_CERT_MODE=letsencrypt
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_ACME_EMAIL=ci@stack.test
TRAEFIK_ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory
TRAEFIK_ACME_STORAGE_FILE=/tmp/setup-server-stack-ci/traefik/acme.json
TRAEFIK_TLS_CHECK_WAIT_SECONDS=0
TRAEFIK_IMAGE=traefik:v3.6
REGISTRY_IMAGE=registry:2
DOCKER_AUTH_IMAGE=cesanta/docker_auth:1
PORTAINER_IMAGE=portainer/portainer-ce:latest
WATCHTOWER_IMAGE=nickfedor/watchtower:latest
SEMAPHORE_IMAGE=semaphoreui/semaphore:latest
DOKU_IMAGE=amerkurev/doku:latest
DUPLICATI_IMAGE=linuxserver/duplicati:latest
GOCRON_IMAGE=ghcr.io/flohoss/gocron:latest
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:1
BESZEL_IMAGE=henrygd/beszel:latest
BESZEL_AGENT_IMAGE=henrygd/beszel-agent:latest
FILEBROWSER_IMAGE=filebrowser/filebrowser:v2-s6
NGINX_IMAGE=nginx:1.27-alpine
NGINX_HOST=ci.stack.test
DEPLOYER_IMAGE=
MONGO_IMAGE=mongo:7
POSTGRES_IMAGE=postgres:16-alpine
MARIADB_IMAGE=mariadb:11
MYSQL_IMAGE=mysql:8
MONGO_EXPRESS_IMAGE=mongo-express:latest
PGADMIN_IMAGE=dpage/pgadmin4:latest
ADMINER_IMAGE=adminer:latest
FILEBROWSER_ROOT_PATH=/tmp/setup-server-stack-ci/filebrowser/files
FILEBROWSER_PUID=1000
FILEBROWSER_PGID=1000
DEPLOYER_IMAGE_EFFECTIVE=
DEPLOYER_NODE_ENV=production
DEPLOYER_AUTH_MODE=dual
DEPLOYER_ADMIN_USER=admin
DEPLOYER_ADMIN_PASSWORD=test-deployer-admin
DEPLOYER_SESSION_SECRET=test-deployer-session-secret
DEPLOY_BASE_PATH=/opt/deploy-data
DEPLOYER_DEFAULT_PULL_POLICY=always
DEPLOYER_PULL_MAX_ATTEMPTS=3
DEPLOYER_CONTAINER_LIMIT=0
DEPLOYER_MANAGED_LABEL=managed-by
DEPLOYER_MANAGED_LABEL_VALUE=deployer
DEPLOYER_REGISTRY_HOST=
DEPLOYER_REGISTRY_USER=
DEPLOYER_REGISTRY_PASSWORD=
DEPLOYER_REGISTRY_CREDENTIALS_JSON=[]
DEPLOYER_API_KEY=test-deployer-api-key
REGISTRY_AUTH_TOKEN_ISSUER=setup-server-registry-ci
REGISTRY_USER=registryadmin
REGISTRY_PASSWORD=test-registry-password
REGISTRY_PULL_USER=registrypull
REGISTRY_PULL_PASSWORD=test-registry-pull-password
WATCHTOWER_SCHEDULE="0 0 4 * * *"
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_PASSWORD=test-semaphore-password
SEMAPHORE_ADMIN_NAME=Admin
SEMAPHORE_ADMIN_EMAIL=admin@ci.stack.test
SEMAPHORE_ACCESS_KEY_ENCRYPTION=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
DOKU_DASHBOARD_USER=doku
DUP_PUID=1000
DUP_PGID=1000
DUPLICATI_WEBSERVICE_PASSWORD=test-duplicati-password
DUPLICATI_SETTINGS_ENCRYPTION_KEY=test-duplicati-settings-key
FILEBROWSER_USER=admin
FILEBROWSER_PASSWORD=test-filebrowser-password
BESZEL_HUB_LOCAL_PORT=8090
BESZEL_APP_URL=https://beszel.ci.stack.test
BESZEL_HUB_URL=http://localhost:8090
BESZEL_AGENT_DISABLE_SSH=true
BESZEL_USER_EMAIL=admin@ci.stack.test
BESZEL_USER_PASSWORD=test-beszel-password
BESZEL_SYSTEM_NAME=
BESZEL_DATA_PATH=/tmp/setup-server-stack-ci/beszel
BESZEL_AGENT_DATA_PATH=/tmp/setup-server-stack-ci/beszel-agent
ENABLE_MONGO=0
ENABLE_POSTGRES=0
ENABLE_MARIADB=0
ENABLE_MYSQL=0
MONGO_ROOT_USER=mongoadmin
MONGO_ROOT_PASSWORD=test-mongo-password
POSTGRES_USER=app
POSTGRES_PASSWORD=test-postgres-password
POSTGRES_DB=postgres
MARIADB_USER=app
MARIADB_PASSWORD=test-mariadb-password
MARIADB_DATABASE=app
MARIADB_ROOT_PASSWORD=test-mariadb-root
MYSQL_USER=app
MYSQL_PASSWORD=test-mysql-password
MYSQL_DATABASE=app
MYSQL_ROOT_PASSWORD=test-mysql-root
ENABLE_MONGO_EXPRESS=0
MONGO_EXPRESS_USER=mexpress
MONGO_EXPRESS_PASSWORD=test-mongo-express-password
ENABLE_PGADMIN=0
PGADMIN_EMAIL=pgadmin@ci.stack.test
PGADMIN_PASSWORD=test-pgadmin-password
ENABLE_ADMINER=0
ADMINER_DEFAULT_SERVER=
