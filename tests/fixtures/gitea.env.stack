DOMAIN=ci.stack.test
STACK_ROOT=/tmp/setup-server-stack-ci-gitea
COMPOSE_PROFILES=traefik,gitea,gitea-runner
GITEA_IMAGE=gitea/gitea:1.23
GITEA_RUNNER_IMAGE=gitea/act_runner:0.2.11
GITEA_DATA_PATH=/tmp/setup-server-stack-ci-gitea/gitea
GITEA_RUNNER_DATA_PATH=/tmp/setup-server-stack-ci-gitea/gitea-runner
GITEA_HOST=gitea.ci.stack.test
GITEA_ROOT_URL=https://gitea.ci.stack.test/
GITEA_SSH_PORT=2222
GITEA_PUID=1000
GITEA_PGID=1000
GITEA_DB_TYPE=sqlite3
GITEA_ADMIN=admin
GITEA_ADMIN_EMAIL=admin@ci.stack.test
GITEA_ADMIN_PASSWORD=test-gitea-admin
GITEA_RUNNER_INSTANCE_URL=https://gitea.ci.stack.test
GITEA_RUNNER_NAME=stack-runner
GITEA_RUNNER_REGISTRATION_TOKEN=
TRAEFIK_CERT_RESOLVER=letsencrypt
TZ=UTC
