# CI fixture: default full stack (all default panels + registry).
# shellcheck disable=SC1091
source "$(dirname "${BASH_SOURCE[0]}")/_common.env.stack"

ENABLE_TRAEFIK=1
ENABLE_PORTAINER=1
ENABLE_DOKU=1
ENABLE_WATCHTOWER=1
ENABLE_SEMAPHORE=1
ENABLE_DUPLICATI=1
ENABLE_UPTIME_KUMA=1
ENABLE_BESZEL=1
ENABLE_BESZEL_AGENT=1
ENABLE_FILEBROWSER=1
ENABLE_NGINX=1
ENABLE_REGISTRY=1
ENABLE_DOCKER_AUTH=1
COMPOSE_PROFILES=traefik,portainer,doku,watchtower,semaphore,duplicati,kuma,beszel,beszel-agent,filebrowser,nginx,registry,registry-auth
