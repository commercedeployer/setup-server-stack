# Local config and generated passwords.
# Server working secrets: .secrets. Windows downloads are archived in secrets/.
.env
.env.local
.env.*.local
.env.stack
.secrets
**/.secrets
.setup-server-stack-secrets
**/.setup-server-stack-secrets
secrets/
**/secrets/
secrets-backup.txt
*.secrets-backup

# Traefik / TLS
traefik/acme.json
certs/*
!certs/.gitkeep
!certs/README.md
!certs/README.ru.md

# Generated JWT keys (registry ↔ docker_auth)
certs/*.pem

# Rendered configs (setup-server-stack.sh)
config/docker_auth/auth_config.yml
config/docker/config.json
config/traefik/htpasswd
config/traefik/htpasswd-doku
config/pgadmin/

# Local Compose overrides (optional)
docker-compose.override.yml

# Generated runtime data (STACK_ROOT=. on VPS)
traefik/
filebrowser/

# IDE / agent (local only)
.cursor/
.cursorignore
