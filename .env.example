# =============================================================================
# setup-server-stack .env.example
# Modular mode: each service can be toggled via ENABLE_*.
# =============================================================================

# -----------------------------------------------------------------------------
# [A] Project base: domain, timezone, paths
# -----------------------------------------------------------------------------
DOMAIN=example.com
ACME_EMAIL=you@example.com
TZ=UTC
# Data root on the server: traefik/acme.json, certs, config, etc.
STACK_ROOT=.
# For deploy-from-windows.ps1 (default on VPS: /opt/setup-server-stack):
# SETUP_SERVER_STACK_ROOT=/opt/setup-server-stack
# SSH port (UFW/fail2ban/deploy script):
# SSH_PORT=22

# -----------------------------------------------------------------------------
# [B] Service toggles (1=ON, 0=OFF)
# -----------------------------------------------------------------------------
ENABLE_TRAEFIK=1
# ENABLE_TRAEFIK=0 only if every HTTPS panel is off (portainer, registry, kuma, …). Watchtower and DB engines without web UIs may stay on.
ENABLE_PORTAINER=1
ENABLE_DOKU=1
ENABLE_WATCHTOWER=1
ENABLE_SEMAPHORE=1
ENABLE_DUPLICATI=1
ENABLE_UPTIME_KUMA=1
ENABLE_FILEBROWSER=1
ENABLE_REGISTRY=1
ENABLE_DOCKER_AUTH=1
ENABLE_DEPLOYER=0
ENABLE_MONGO=0
ENABLE_POSTGRES=0
ENABLE_MARIADB=0
ENABLE_MYSQL=0
ENABLE_MONGO_EXPRESS=0
ENABLE_PGADMIN=0
ENABLE_ADMINER=0

# -----------------------------------------------------------------------------
# [C] Container images
# -----------------------------------------------------------------------------
TRAEFIK_IMAGE=traefik:v3.6
REGISTRY_IMAGE=registry:2
DOCKER_AUTH_IMAGE=cesanta/docker_auth:1
PORTAINER_IMAGE=portainer/portainer-ce:latest
WATCHTOWER_IMAGE=nickfedor/watchtower:latest
SEMAPHORE_IMAGE=semaphoreui/semaphore:latest
DOKU_IMAGE=amerkurev/doku:latest
DUPLICATI_IMAGE=lscr.io/linuxserver/duplicati:latest
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:1
FILEBROWSER_IMAGE=filebrowser/filebrowser:v2-s6
DEPLOYER_IMAGE=docker.io/commercedeployer/deployer:latest
MONGO_IMAGE=mongo:7
POSTGRES_IMAGE=postgres:16-alpine
MARIADB_IMAGE=mariadb:11
MYSQL_IMAGE=mysql:8
MONGO_EXPRESS_IMAGE=mongo-express:latest
PGADMIN_IMAGE=dpage/pgadmin4:latest
ADMINER_IMAGE=adminer:latest

# -----------------------------------------------------------------------------
# [D] Docker Engine on the host
# -----------------------------------------------------------------------------
INSTALL_DOCKER=1
# Common VPS fallback when dockerd fails with iptables/nft.
DOCKER_AUTO_IPTABLES_OFF=1

# -----------------------------------------------------------------------------
# [E] Registry + docker_auth (token flow)
# -----------------------------------------------------------------------------
REGISTRY_AUTH_TOKEN_ISSUER=setup-server-registry
REGISTRY_USER=registryadmin
# Empty = generated in .setup-server-stack-secrets.
REGISTRY_PASSWORD=
# Pull-only account (Watchtower, read-only clients). Empty password = generated in secrets.
REGISTRY_PULL_USER=registrypull
REGISTRY_PULL_PASSWORD=
# Empty = derived from REGISTRY_PASSWORD (admin bcrypt only; pull uses REGISTRY_PULL_PASSWORD_BCRYPT).
REGISTRY_USER_PASSWORD_BCRYPT=
REGISTRY_PULL_PASSWORD_BCRYPT=
# Optional: local images to push to registry on install.
# Separators: comma or ; (single line).
# Example: REGISTRY_SEED_IMAGES=myapp:latest,ghcr.io/acme/api:1.4;redis:7
# Empty = skip seed push.
REGISTRY_SEED_IMAGES=

# Extra external registries for host login during install.
# Format: set count and EXTRA_REGISTRY_{N}_HOST/USER/PASSWORD blocks.
# HOST may include https:// or not (normalized automatically).
# Example:
# EXTRA_REGISTRY_COUNT=2
# EXTRA_REGISTRY_1_HOST=ghcr.io
# EXTRA_REGISTRY_1_USER=myuser
# EXTRA_REGISTRY_1_PASSWORD=token1
# EXTRA_REGISTRY_2_HOST=registry.gitlab.com
# EXTRA_REGISTRY_2_USER=gitlab-user
# EXTRA_REGISTRY_2_PASSWORD=token2
EXTRA_REGISTRY_COUNT=0
EXTRA_REGISTRY_1_HOST=
EXTRA_REGISTRY_1_USER=
EXTRA_REGISTRY_1_PASSWORD=

# Retries for registry operations during install (login/pull/push/up).
REGISTRY_OPERATION_RETRIES=3
# Exponential backoff: base * 2^(n-1), capped at max.
REGISTRY_RETRY_BACKOFF_BASE_SEC=2
REGISTRY_RETRY_BACKOFF_MAX_SEC=10

# -----------------------------------------------------------------------------
# [F] Watchtower
# -----------------------------------------------------------------------------
WATCHTOWER_SCHEDULE=0 0 4 * * *

# -----------------------------------------------------------------------------
# [G] Semaphore
# -----------------------------------------------------------------------------
SEMAPHORE_ADMIN=admin
SEMAPHORE_ADMIN_PASSWORD=
SEMAPHORE_ADMIN_NAME=Admin
SEMAPHORE_ADMIN_EMAIL=admin@example.com
SEMAPHORE_ACCESS_KEY_ENCRYPTION=

# -----------------------------------------------------------------------------
# [H] Duplicati + Kuma + Filebrowser
# Duplicati: compose persists UI config only (volume duplicati_config). Backup sources and remote storage — in Duplicati UI; optional bind mounts in docker-compose.yml.
# -----------------------------------------------------------------------------
DUP_PUID=1000
DUP_PGID=1000
# Host directory mounted rw into Filebrowser. Empty = $STACK_ROOT/filebrowser/files (recommended). Do not use "/" on production.
FILEBROWSER_ROOT_PATH=
FILEBROWSER_PUID=1000
FILEBROWSER_PGID=1000

# -----------------------------------------------------------------------------
# [I] Deployer runtime (toggle: [B] ENABLE_DEPLOYER, image: [C] DEPLOYER_IMAGE)
# -----------------------------------------------------------------------------
# Optional: login before pull (private image on Docker Hub / GHCR)
# DEPLOYER_IMAGE_REGISTRY_HOST=docker.io
# DEPLOYER_IMAGE_REGISTRY_USER=
# DEPLOYER_IMAGE_REGISTRY_PASSWORD=

# Deployer runtime env:
DEPLOYER_NODE_ENV=production
DEPLOYER_ADMIN_USER=admin
DEPLOYER_ADMIN_PASSWORD=
DEPLOYER_SESSION_SECRET=
DEPLOY_BASE_PATH=/opt/deploy-data
# Pull policy inside Deployer (for app images it deploys):
# always       - try registry pull (fallback to local image if present)
# ifNotPresent - skip pull when local image exists
DEPLOYER_DEFAULT_PULL_POLICY=always
DEPLOYER_PULL_MAX_ATTEMPTS=3
DEPLOYER_CONTAINER_LIMIT=0
DEPLOYER_MANAGED_LABEL=managed-by
DEPLOYER_MANAGED_LABEL_VALUE=deployer
DEPLOYER_API_KEY=

# -----------------------------------------------------------------------------
# [J] Databases and web UIs
# -----------------------------------------------------------------------------
MONGO_ROOT_USER=mongoadmin
MONGO_ROOT_PASSWORD=
POSTGRES_USER=app
POSTGRES_PASSWORD=
POSTGRES_DB=app
MARIADB_USER=app
MARIADB_PASSWORD=
MARIADB_DATABASE=app
MARIADB_ROOT_PASSWORD=
MYSQL_USER=app
MYSQL_PASSWORD=
MYSQL_DATABASE=app
MYSQL_ROOT_PASSWORD=
MONGO_EXPRESS_USER=mexpress
MONGO_EXPRESS_PASSWORD=
PGADMIN_EMAIL=pgadmin@example.com
PGADMIN_PASSWORD=
# Postgres host/port for pgAdmin auto-connect (container name on proxynet).
PGADMIN_POSTGRES_HOST=postgres
PGADMIN_POSTGRES_PORT=5432
# DB container name for Adminer default (postgres | mariadb | mysql). Empty = auto.
ADMINER_DEFAULT_SERVER=

# -----------------------------------------------------------------------------
# [K] Host security and access
# -----------------------------------------------------------------------------
CREATE_ADMIN_USER=1
ADMIN_USERNAME=adminops
ADMIN_SUDO_NOPASSWD=1
APPLY_SSH_HARDENING=1
# Paste SSH public key (required for safe SSH hardening):
SSH_PUBLIC_KEY=
UFW_ENABLE=1
INSTALL_FAIL2BAN=1
INSTALL_UNATTENDED_UPGRADES=1
