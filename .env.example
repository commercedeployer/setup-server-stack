# =============================================================================
# setup-server-stack .env.example
# Full QA/example stack: remove ENABLE_*=1 lines you do not need.
# Toggle rule: a missing ENABLE_* means 0, so personal .env files can stay small.
# Secret rule: leave a password/secret empty and the installer writes one to .secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# [A] Core project settings
# -----------------------------------------------------------------------------
DOMAIN=example.com
ACME_EMAIL=you@example.com
STACK_ADMIN_USER=admin
STACK_ADMIN_EMAIL=admin@example.com
TZ=UTC

# Data root on the server: traefik, certs, config, nginx/public, and .env.stack.
STACK_ROOT=.

# -----------------------------------------------------------------------------
# [B] TLS certificates
# -----------------------------------------------------------------------------
# auto        = $STACK_ROOT/certs/<host> first, then production Let's Encrypt.
# provided    = only $STACK_ROOT/certs/<host>; no Let's Encrypt requests.
# letsencrypt = only production Let's Encrypt; custom certs are ignored by routing.
# staging     = Let's Encrypt staging for QA reinstall loops; browser warning is expected.
# selfsigned  = no custom certs and no Let's Encrypt; browser warning is expected.
TRAEFIK_CERT_MODE=auto

# Custom cert layout: $STACK_ROOT/certs/<host>/fullchain.pem + privkey.pem.
# See certs/README.md.
TRAEFIK_TLS_CHECK_WAIT_SECONDS=20

# -----------------------------------------------------------------------------
# [C] Windows deploy and SSH entrypoint
# -----------------------------------------------------------------------------
# Remote install directory used by deploy-from-windows.ps1.
# SETUP_SERVER_STACK_ROOT=/opt/setup-server-stack

# SSH port used by deploy script, UFW, and fail2ban.
# SSH_PORT=22

# -----------------------------------------------------------------------------
# [D] Service toggles (1=ON, 0=OFF)
# -----------------------------------------------------------------------------
ENABLE_TRAEFIK=1
ENABLE_PORTAINER=1
ENABLE_DOKU=1
ENABLE_WATCHTOWER=1
ENABLE_SEMAPHORE=1
ENABLE_DUPLICATI=1
ENABLE_GOCRON=0
ENABLE_UPTIME_KUMA=1
ENABLE_BESZEL=1
# Local Beszel agent for this server; defaults to ENABLE_BESZEL when unset.
ENABLE_BESZEL_AGENT=1
ENABLE_FILEBROWSER=1
ENABLE_NGINX=1
ENABLE_REGISTRY=1
ENABLE_DOCKER_AUTH=1
ENABLE_DEPLOYER=1
ENABLE_MONGO=1
ENABLE_POSTGRES=1
ENABLE_MARIADB=1
ENABLE_MYSQL=1
ENABLE_MONGO_EXPRESS=1
ENABLE_PGADMIN=1
ENABLE_ADMINER=1

# -----------------------------------------------------------------------------
# [E] Container images
# -----------------------------------------------------------------------------
TRAEFIK_IMAGE=traefik:v3.6
REGISTRY_IMAGE=registry:2
DOCKER_AUTH_IMAGE=cesanta/docker_auth:1
PORTAINER_IMAGE=portainer/portainer-ce:latest
WATCHTOWER_IMAGE=nickfedor/watchtower:latest
SEMAPHORE_IMAGE=semaphoreui/semaphore:latest
DOKU_IMAGE=amerkurev/doku:latest
DUPLICATI_IMAGE=linuxserver/duplicati:latest
GOCRON_IMAGE=ghcr.io/flohoss/gocron:latest
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:1
BESZEL_IMAGE=henrygd/beszel:latest
BESZEL_AGENT_IMAGE=henrygd/beszel-agent:latest
FILEBROWSER_IMAGE=filebrowser/filebrowser:v2-s6
NGINX_IMAGE=nginx:1.27-alpine
DEPLOYER_IMAGE=commercedeployer/deployer:latest
MONGO_IMAGE=mongo:7
POSTGRES_IMAGE=postgres:16-alpine
MARIADB_IMAGE=mariadb:11
MYSQL_IMAGE=mysql:8
MONGO_EXPRESS_IMAGE=mongo-express:latest
PGADMIN_IMAGE=dpage/pgadmin4:latest
ADMINER_IMAGE=adminer:latest

# -----------------------------------------------------------------------------
# [F] Host Docker and network retries
# -----------------------------------------------------------------------------
INSTALL_DOCKER=1
# Fallback for VPS kernels where dockerd fails with iptables/nft.
DOCKER_AUTO_IPTABLES_OFF=1

# Retries for apt, curl, docker login/pull/push, and compose up.
REGISTRY_OPERATION_RETRIES=3
REGISTRY_RETRY_BACKOFF_BASE_SEC=2
REGISTRY_RETRY_BACKOFF_MAX_SEC=10

# -----------------------------------------------------------------------------
# [G] Registry and registry auth
# -----------------------------------------------------------------------------
REGISTRY_AUTH_TOKEN_ISSUER=setup-server-registry

# Optional override: separate Registry admin login. Empty/commented = STACK_ADMIN_USER.
# REGISTRY_USER=
REGISTRY_PASSWORD=

# Pull-only account for Watchtower and read-only clients.
REGISTRY_PULL_USER=registrypull
REGISTRY_PULL_PASSWORD=

# Empty = installer derives bcrypt hashes from the plain passwords above.
REGISTRY_USER_PASSWORD_BCRYPT=
REGISTRY_PULL_PASSWORD_BCRYPT=

# Optional local images to push on install; separators: comma or semicolon.
# Example: REGISTRY_SEED_IMAGES=myapp:latest,ghcr.io/acme/api:1.4;redis:7
REGISTRY_SEED_IMAGES=

# Extra external registries for host docker login during install.
# Example count=2 then fill EXTRA_REGISTRY_1_* and EXTRA_REGISTRY_2_*.
EXTRA_REGISTRY_COUNT=0
EXTRA_REGISTRY_1_HOST=
EXTRA_REGISTRY_1_USER=
EXTRA_REGISTRY_1_PASSWORD=

# -----------------------------------------------------------------------------
# [H] Operations services
# -----------------------------------------------------------------------------
WATCHTOWER_SCHEDULE=0 0 4 * * *

# Optional override: separate Semaphore login. Empty/commented = STACK_ADMIN_USER.
# SEMAPHORE_ADMIN=
SEMAPHORE_ADMIN_PASSWORD=

# Optional override: Semaphore display name. Empty/commented = STACK_ADMIN_USER.
# SEMAPHORE_ADMIN_NAME=

# Optional override: Semaphore email. Empty/commented = STACK_ADMIN_EMAIL.
# SEMAPHORE_ADMIN_EMAIL=
SEMAPHORE_ACCESS_KEY_ENCRYPTION=

# Optional override: separate Doku login. Empty/commented = STACK_ADMIN_USER.
# DOKU_DASHBOARD_USER=

# Duplicati persists UI config only; backup sources and destinations are set in its UI.
DUP_PUID=1000
DUP_PGID=1000
DUPLICATI_WEBSERVICE_PASSWORD=
DUPLICATI_SETTINGS_ENCRYPTION_KEY=

# gocron — cron scheduler + web UI for rsync/restic/rclone jobs (YAML config).
# Installer writes ${GOCRON_DATA_PATH}/config.yaml; tools install on container start.
# Comma or semicolon list; empty = rsync. Full list: apprise, borgbackup, docker, git,
# podman, rclone, rdiff-backup, restic, rsync, logrotate, sqlite3, kopia
# GOCRON_SOFTWARE=rsync,restic,rclone

# Beszel — server monitoring. The installer auto-registers the local agent with
# the hub (reads the hub key + universal token via API), so it watches this
# server out of the box; no manual "Add System" step is needed.
# Optional override: dashboard login email. Empty/commented = STACK_ADMIN_EMAIL.
# BESZEL_USER_EMAIL=
# Dashboard login password. Empty = installer writes one to .secrets.
BESZEL_USER_PASSWORD=
# Public URL of the hub. Empty/commented = https://beszel.${DOMAIN}.
# BESZEL_APP_URL=
# Friendly name for this server in the dashboard. Empty/commented = hostname.
# BESZEL_SYSTEM_NAME=
# Loopback port used locally by the installer and the agent (not exposed publicly).
# BESZEL_HUB_LOCAL_PORT=8090

# Host directory Filebrowser exposes. Default /opt shows both the stack
# (/opt/setup-server-stack) and Deployer data (/opt/deploy-data).
# Use / to manage the whole server, or a single dir to narrow access.
FILEBROWSER_ROOT_PATH=/opt
# Optional override: separate Filebrowser login. Empty/commented = STACK_ADMIN_USER.
# FILEBROWSER_USER=
FILEBROWSER_PASSWORD=
# Runs as root (0) so the admin fully owns the mounted directory (read+write).
# Set a non-root PUID/PGID to limit it to files owned by that user.
FILEBROWSER_PUID=0
FILEBROWSER_PGID=0

# Optional static-site host. Empty/commented = DOMAIN root, e.g. https://example.com.
# Files are always served from $STACK_ROOT/nginx/public and are never overwritten when non-empty.
# NGINX_HOST=

# -----------------------------------------------------------------------------
# [I] Deployer runtime
# -----------------------------------------------------------------------------
# Optional docker login before pulling a private Deployer image.
# DEPLOYER_IMAGE_REGISTRY_HOST=docker.io
# DEPLOYER_IMAGE_REGISTRY_USER=
# DEPLOYER_IMAGE_REGISTRY_PASSWORD=

DEPLOYER_NODE_ENV=production

# How clients authenticate to Deployer:
# dual = web panel and API key (default); api = API key only; ui = web panel only.
DEPLOYER_AUTH_MODE=dual

# Optional override: separate Deployer login. Empty/commented = STACK_ADMIN_USER.
# DEPLOYER_ADMIN_USER=
DEPLOYER_ADMIN_PASSWORD=

# Session signing secret for the web panel (also used for MCP key hashes).
DEPLOYER_SESSION_SECRET=

# Public HTTPS URL for Deployer (MCP hints, Cursor). Empty = https://deployer.${DOMAIN} on stack.
# DEPLOYER_PUBLIC_BASE_URL=https://deployer.example.com

# MCP: comma-separated tool names hidden from agents (tools/list + tools/call).
# DEPLOYER_MCP_TOOLS_DENY=deployer_container_delete,deployer_template_delete

# API secret for Commerce/scripts (x-api-key header).
# In ui mode the key is ignored and not generated.
DEPLOYER_API_KEY=

DEPLOY_BASE_PATH=/opt/deploy-data

# Pull policy inside Deployer for app images.
# always       = try registry pull, fallback to local image if present.
# ifNotPresent = skip pull when local image exists.
DEPLOYER_DEFAULT_PULL_POLICY=always
DEPLOYER_PULL_MAX_ATTEMPTS=3
DEPLOYER_CONTAINER_LIMIT=0
DEPLOYER_MANAGED_LABEL=managed-by
DEPLOYER_MANAGED_LABEL_VALUE=deployer

# Tools installed inside the Deployer container on start (provision/deprovision commands).
# Comma or semicolon list; empty = bash,curl. node is always present (base image).
# Keys: bash, psql, mysql, mariadb, mongosh, curl, jq, python3, openssl, rsync,
#       openssh, bind, zip (+ aliases postgres, mongo, ssh, dig)
# Postgres tenant templates (umami-pg): add psql — e.g. bash,curl,psql
# DEPLOYER_SOFTWARE=bash,curl,psql,jq

# -----------------------------------------------------------------------------
# [J] Databases
# -----------------------------------------------------------------------------
# Each engine installs minimally; create databases/users yourself afterwards.

# Mongo: only the root user is created (Mongo makes databases on first write).
# Optional override: separate Mongo root login. Empty/commented = STACK_ADMIN_USER.
# MONGO_ROOT_USER=
MONGO_ROOT_PASSWORD=

# Superuser lands in the default postgres DB (no extra DB named after POSTGRES_USER).
# Product DBs (Nextcloud, Commerce, …) — create later via create-db.sh or pgAdmin.
# Optional override: separate Postgres login. Empty/commented = STACK_ADMIN_USER.
# POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

# MariaDB/MySQL: empty = root-only. To add an app user, set *_USER AND *_DATABASE
# together (a user without a database has no privileges); the password autogenerates.
# MARIADB_USER=
# MARIADB_DATABASE=
MARIADB_ROOT_PASSWORD=

# MYSQL_USER=
# MYSQL_DATABASE=
MYSQL_ROOT_PASSWORD=

# -----------------------------------------------------------------------------
# [K] Database web UIs
# -----------------------------------------------------------------------------
# Optional override: separate mongo-express login. Empty/commented = STACK_ADMIN_USER.
# MONGO_EXPRESS_USER=
MONGO_EXPRESS_PASSWORD=

# Optional override: pgAdmin login email. Empty/commented = STACK_ADMIN_EMAIL.
# PGADMIN_EMAIL=
PGADMIN_PASSWORD=

# Postgres host/port for pgAdmin auto-connect.
PGADMIN_POSTGRES_HOST=postgres
PGADMIN_POSTGRES_PORT=5432

# DB container name for Adminer default (postgres | mariadb | mysql). Empty = auto.
ADMINER_DEFAULT_SERVER=

# -----------------------------------------------------------------------------
# [L] Host security and access
# -----------------------------------------------------------------------------
CREATE_ADMIN_USER=1

# Optional override: Linux sudo user. Empty/commented = STACK_ADMIN_USER.
# ADMIN_USERNAME=
ADMIN_SUDO_NOPASSWD=1

APPLY_SSH_HARDENING=1
# Paste one SSH public key line before hardening or Windows deploy.
SSH_PUBLIC_KEY=

UFW_ENABLE=1
INSTALL_FAIL2BAN=1
INSTALL_UNATTENDED_UPGRADES=1

# -----------------------------------------------------------------------------
# [M] Advanced: per-service data paths (optional)
# -----------------------------------------------------------------------------
# Each service stores its data under $STACK_ROOT/<service> by default, so one
# copy of $STACK_ROOT is a full backup. Override a path only to move data
# elsewhere, e.g. a large database onto a separate disk.
# NOTE: a path OUTSIDE $STACK_ROOT still works and is left untouched by the
# Windows deploy (it only writes inside $STACK_ROOT), but it is NOT included
# when you back up by copying $STACK_ROOT — back such a path up separately.
# Defaults shown below:
# REGISTRY_DATA_PATH=${STACK_ROOT}/registry
# PORTAINER_DATA_PATH=${STACK_ROOT}/portainer
# SEMAPHORE_DATA_PATH=${STACK_ROOT}/semaphore
# DUPLICATI_DATA_PATH=${STACK_ROOT}/duplicati
# GOCRON_DATA_PATH=${STACK_ROOT}/gocron
# KUMA_DATA_PATH=${STACK_ROOT}/kuma
# BESZEL_DATA_PATH=${STACK_ROOT}/beszel
# BESZEL_AGENT_DATA_PATH=${STACK_ROOT}/beszel-agent
# PGADMIN_DATA_PATH=${STACK_ROOT}/pgadmin
# POSTGRES_DATA_PATH=${STACK_ROOT}/postgres
# MONGO_DATA_PATH=${STACK_ROOT}/mongo
# MARIADB_DATA_PATH=${STACK_ROOT}/mariadb
# MYSQL_DATA_PATH=${STACK_ROOT}/mysql
