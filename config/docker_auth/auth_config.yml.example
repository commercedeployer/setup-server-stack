# docker_auth (cesanta/docker_auth) — copied to auth_config.yml with substituted secrets
# (setup-server-stack.sh renders from this template using .env / .setup-server-stack-secrets).
#
# Must match registry (see INSTALL.md — registry troubleshooting):
#   REGISTRY_AUTH_TOKEN_ISSUER     == token.issuer (below)
#   REGISTRY_AUTH_TOKEN_REALM      == public HTTPS realm URL, usually https://auth.${DOMAIN}/auth
#   REGISTRY_AUTH_TOKEN_SERVICE    == token flow service name (often registry FQDN)
#   REGISTRY_AUTH_TOKEN_ROOTCERTBUNDLE == same PEM as token.certificate (JWT public key)
#
# User passwords are bcrypt ($2y$...); see htpasswd -nbB or setup-server-stack.sh

server:
  addr: ":5001"

token:
  issuer: "${REGISTRY_AUTH_TOKEN_ISSUER}"
  expiration: 900
  certificate: "/ssl/registry-token.pem"
  key: "/ssl/registry-token-key.pem"

users:
  "${REGISTRY_USER}":
    password: "${REGISTRY_USER_PASSWORD_BCRYPT}"
  "${REGISTRY_PULL_USER}":
    password: "${REGISTRY_PULL_PASSWORD_BCRYPT}"

acl:
  - match: { account: "${REGISTRY_USER}" }
    actions: ["*"]
  - match: { account: "${REGISTRY_PULL_USER}" }
    actions: ["pull"]
